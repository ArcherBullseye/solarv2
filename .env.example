# Solis Cloud API credentials
# Get these from Solis Cloud portal: Account -> API Management
SOLIS_API_KEY=your_api_key_here
SOLIS_API_SECRET=your_api_secret_here
SOLIS_BASE_URL=https://www.soliscloud.com:13333

# Solis inverter serial number (found on the inverter label or in the Solis app)
SOLIS_INVERTER_SN=your_inverter_serial_number_here

# LuxOS miner settings
# The local IP of the miner on your network — no username/password needed
LUXOS_MINER_IP=192.168.1.100

# Control settings
SOC_ON_THRESHOLD=80.0
SOC_OFF_THRESHOLD=80.0
POLL_INTERVAL_SECONDS=60
